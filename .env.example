# Gmail credentials — use an App Password, NOT your account password
# Docs: https://support.google.com/accounts/answer/185833
GMAIL_SENDER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: send digest to a different address (defaults to GMAIL_SENDER)
# GMAIL_RECEIVER=other@gmail.com

# Frontend — change if running backend on a different host/port
VITE_API_URL=http://localhost:8000
